@model Obs_Proje.Models.OgrenciNotu

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Öğrenci Düzenle - Harf Notu Destekli</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">

    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h3 class="mb-0">✏️ Öğrenci Bilgilerini Güncelle</h3>
                <span id="liveHarfNotu" class="badge bg-dark fs-4">--</span> </div>
            <div class="card-body">
                
                <form method="post" action="/Home/NotGuncelle">
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Öğrenci Adı Soyadı:</label>
                        <input type="text" name="StudentName" value="@Model.StudentName" class="form-control" required />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Sınıf Seviyesi:</label>
                            <input type="number" name="ClassLevel" value="@Model.ClassLevel" class="form-control" required />
                        </div>
                        <div class="col-md-6 text-center pt-4">
                            <div class="alert alert-info py-2">
                                <strong>Mevcut Ortalama:</strong> @Model.Average.ToString("0.00")
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-primary">Vize Notu (%40):</label>
                            <input type="number" step="any" id="vizeInput" name="MidtermExam" value="@Model.MidtermExam" class="form-control border-primary" required oninput="hesaplaHarfNotu()" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-success">Final Notu (%60):</label>
                            <input type="number" step="any" id="finalInput" name="FinalExam" value="@Model.FinalExam" class="form-control border-success" required oninput="hesaplaHarfNotu()" />
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-success btn-lg shadow-sm">💾 Değişiklikleri Uygula ve Kaydet</button>
                        <a href="/Home/OgretmenPaneli" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function hesaplaHarfNotu() {
            let vize = parseFloat(document.getElementById('vizeInput').value) || 0;
            let final = parseFloat(document.getElementById('finalInput').value) || 0;
            let ortalama = (vize * 0.4) + (final * 0.6);
            let harf = "";

            if (ortalama >= 90) harf = "AA";
            else if (ortalama >= 85) harf = "BA";
            else if (ortalama >= 80) harf = "BB";
            else if (ortalama >= 75) harf = "CB";
            else if (ortalama >= 70) harf = "CC";
            else if (ortalama >= 65) harf = "DC";
            else if (ortalama >= 60) harf = "DD";
            else if (ortalama >= 50) harf = "FD";
            else harf = "FF";

            let rozet = document.getElementById('liveHarfNotu');
            rozet.innerText = harf;

            // Renklendirme
            if (ortalama >= 60) rozet.className = "badge bg-success fs-4";
            else if (ortalama >= 50) rozet.className = "badge bg-warning text-dark fs-4";
            else rozet.className = "badge bg-danger fs-4";
        }
        
        // Sayfa yüklendiğinde mevcut notla hesapla
        window.onload = hesaplaHarfNotu;
    </script>
</body>
</html>