@{
    Layout = null; // Üst menü ve alt bilgi (Navbar/Footer) gelmemesi için
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fırat Üniversitesi OBS Giriş</title>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <style>
        /* Paylaştığın CSS kodları buraya gelecek */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Lato', sans-serif; height: 100vh; display: flex; overflow: hidden; background-color: #f8f9fa; }
        
        .brand-section {
            flex: 1.4;
            background: linear-gradient(rgba(0, 51, 102, 0.85), rgba(0, 30, 80, 0.95)), 
                        url('https://images.unsplash.com/photo-1562774053-701939374585?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80') no-repeat center center/cover;
            display: flex; flex-direction: column; justify-content: space-between; padding: 60px; color: #fff;
        }
        .brand-logo { font-family: 'Playfair Display', serif; font-size: 28px; letter-spacing: 2px; font-weight: 700; color: #f0f0f0; }
        .brand-quote h1 { font-family: 'Playfair Display', serif; font-size: 52px; line-height: 1.2; margin-bottom: 25px; color: #d4af37; }
        .brand-quote p { font-size: 18px; opacity: 0.9; max-width: 500px; line-height: 1.6; }
        .brand-footer { font-size: 13px; opacity: 0.6; letter-spacing: 1px; }
        
        .login-section { flex: 1; background-color: #ffffff; display: flex; align-items: center; justify-content: center; }
        .login-wrapper { width: 100%; max-width: 400px; padding: 40px; }
        .login-title { font-family: 'Playfair Display', serif; font-size: 38px; color: #0a192f; margin-bottom: 10px; }
        .login-subtitle { color: #8892b0; margin-bottom: 45px; font-size: 15px; }

        .input-group { position: relative; margin-bottom: 35px; }
        .input-group input { width: 100%; padding: 15px 5px; font-size: 16px; color: #0a192f; border: none; border-bottom: 2px solid #e0e0e0; outline: none; background: transparent; transition: border-color 0.3s; }
        .input-group label { position: absolute; top: 15px; left: 5px; font-size: 16px; color: #8892b0; pointer-events: none; transition: 0.3s ease all; }
        .input-group input:focus ~ label, .input-group input:valid ~ label { top: -12px; font-size: 13px; font-weight: 700; color: #d4af37; }
        .input-group input:focus { border-bottom: 2px solid #d4af37; }

        .btn-premium { width: 100%; padding: 18px; background-color: #0a192f; color: #ffffff; font-size: 15px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; border: none; cursor: pointer; transition: all 0.3s ease; margin-top: 25px; border-radius: 4px; }
        .btn-premium:hover { background-color: #d4af37; color: #0a192f; box-shadow: 0 10px 20px rgba(10, 25, 47, 0.15); }
        .error-msg { color: #d9534f; background: #fdf7f7; padding: 10px; border-radius: 4px; margin-bottom: 20px; text-align: center; border: 1px solid #d9534f; }
    </style>
</head>
<body>
    <div class="brand-section">
        <div class="brand-logo">T.C. FIRAT ÜNİVERSİTESİ</div>
        <div class="brand-quote">
            <h1>Bilim ve Teknoloji<br>Üssü.</h1>
            <p>Öğrenci Bilgi Sistemine (OBS) hoş geldiniz.</p>
        </div>
        <div class="brand-footer">© @DateTime.Now.Year FIRAT ÜNİVERSİTESİ BİLGİ İŞLEM</div>
    </div>

    <div class="login-section">
        <div class="login-wrapper">
            <h2 class="login-title">Sisteme Giriş</h2>
            <p class="login-subtitle">Öğretmen veya Öğrenci bilgilerinizi giriniz.</p>

            <form method="post" action="@Url.Action("GirisYap", "Home")">
                
                @if (ViewBag.Hata != null)
                {
                    <div class="error-msg">@ViewBag.Hata</div>
                }

                <div class="input-group">
                    <input type="text" id="username" name="kullaniciAdi" required>
                    <label for="username">Kullanıcı Adı</label>
                </div>

                <div class="input-group">
                    <input type="password" id="password" name="sifre" required>
                    <label for="password">Şifre</label>
                </div>

                <button type="submit" class="btn-premium">GÜVENLİ GİRİŞ YAP</button>
            </form>
        </div>
    </div>
</body>
</html>